{
  "name": "denkenhub-resource-api",
  "version": "1.0.0",
  "description": "API didática para gestão de recursos do DenkenHub.",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "node",
    "typescript",
    "express",
    "api",
    "denkenhub"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "pg": "^8.22.0",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.8",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "eslint": "^9.5.0",
    "prettier": "^3.3.2",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.34.1",
    "vitest": "^4.1.9"
  }
}
